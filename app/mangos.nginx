server {
    listen 80;
    server_name ima-mangos.com www.ima-mangos.com;

    access_log /var/log/nginx/mangos/access.log;
    error_log /var/log/nginx/mangos/error.log;

    root /home/imanol/projects/wiseutils/pay-trackr/app;
    index index.php;

    # ── Static assets ─────────────────────────────
    location /assets/ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # ── API → server/api/index.php ────────────────
    location /api/ {
        fastcgi_pass unix:/run/php/php8.3-fpm.sock;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME /home/imanol/projects/wiseutils/pay-trackr/server/api/index.php;
        fastcgi_param REQUEST_URI $request_uri;
    }

    # ── Frontend: everything else → app/index.php ─
    location / {
        try_files $uri $uri/ /index.php$is_args$args;
    }

    # ── PHP processing ────────────────────────────
    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_pass unix:/run/php/php8.3-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
    }

    # ── Security: block sensitive files ───────────
    location /includes/ { deny all; }
    location ~ config\.php$ { deny all; }
    location ~ /\.git { deny all; }
    location ~ /node_modules/ { deny all; }
}
