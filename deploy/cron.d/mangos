# Droplet cron for Mangos notifications.
# Install: sudo cp deploy/cron.d/mangos /etc/cron.d/mangos && sudo chmod 644 /etc/cron.d/mangos
# Cron secret lives at /etc/mangos/cron.secret (mode 0640, owner root:www-data).
#
# Schedule (America/Argentina/Buenos_Aires):
#   daily-fijos    08:00 every day
#   weekly-digest  08:00 Sundays  (PR3, not active yet)
#
# Testing tip: set the daily line to "* * * * *" temporarily to fire every
# minute, watch /var/log/mangos-cron.log, then revert to "0 8 * * *".

SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# m h dom mon dow user      command
# TESTING: every minute, hits /cron-test (always fires a push). Switch back to
# /daily on schedule "0 8 * * *" once the pipe is verified end-to-end.
* * * * *   www-data  curl -fsS -X POST -H "X-Cron-Secret: $(cat /etc/mangos/cron.secret)" https://mangos-api.wiseutils.com/api/notifications/cron-test >> /var/log/mangos-cron.log 2>&1
